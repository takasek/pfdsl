tag:
  "priority:high": { style: { color: "#b60205", penwidth: "2" } }

statusStyles:
  done: { fillcolor: "#d4edda", style: filled }
  wip: { fillcolor: "#fff3cd", style: filled }
  todo: { fillcolor: "#f8f9fa", style: filled }
  waiting: { fillcolor: "#f8d7da", style: filled }
  suspended: { fillcolor: "#e2e3e5", style: filled }
---

spec_v006 >> draft_multifile_specs -> [hierarchy_spec, presets_spec, multifile_policy]

spec_v006 >> draft_criteria -> criteria_spec

spec_v006 >> draft_revises -> revises_spec

spec_v006 >> draft_location -> location_spec

spec_v006 >> write_design_notes -> design_notes

[criteria_spec, revises_spec, location_spec, design_notes, external_stakeholders_spec] >> integrate_spec -> spec_v007

spec_v006 >>? integrate_spec

[spec_v006, findings_r12, cli_tool] >> implement_lints -> lint_checker

[spec_v007, lint_checker] >> implement_spec_features -> featured_toolchain

[hierarchy_spec, presets_spec, multifile_policy, featured_toolchain] >> integrate_multifile -> spec_v008

[spec_v008, featured_toolchain] >> implement_multifile -> multifile_toolchain

skill_gen >> restructure_skillgen -> restructured_gen

cli_tool >> publish_cli_v009 -> cli_tool_v009

cli_tool >> layer_audit_assets -> audit_distribution

adr_corpus >> i12_write_article -> article

cli_tool >> i3_build_obsidian_plugin -> obsidian_plugin

spec_v006 >> draft_external_stakeholders -> external_stakeholders_spec

cli_tool >> i119_publish_extension -> published_extension

cli_tool_v009 >> implement_version_cmd -> version_cmd
cli_tool_v009 >> implement_subcommand_help -> subcommand_help
cli_tool_v009 >> implement_stdin -> stdin
cli_tool_v009 >> implement_no_color -> no_color
cli_tool_v009 >> implement_json_output -> json_output

[version_cmd, subcommand_help, stdin, no_color, json_output] >> publish_cli_v0010 -> cli_tool_v0010

cli_tool_v009 >> implement_hover_jump -> hover_jump
cli_tool_v009 >> implement_run_command -> run_command
cli_tool_v009 >> implement_group_hover -> group_hover
cli_tool_v009 >> fix_w002_line -> w002_line

cli_tool_v009 >> implement_index_reindex -> index_reindex

cli_tool_v009 >> implement_node_sort -> node_sort

[cli_tool_v0010, w002_line, index_reindex, node_sort] >> publish_cli_v0011 -> cli_tool_v0011

index_reindex >> integrate_spec_v009 -> spec_v009

[hover_jump, run_command, group_hover] >> publish_ext_v0014 -> ext_v0014

[spec_v009, cli_tool_v0011] >> implement_basepath -> basepath
[basepath, ready_cmd] >> integrate_spec_v0010 -> spec_v0010
spec_v009 >>? integrate_spec_v0010
cli_tool_v0011 >> implement_ready_cmd -> ready_cmd
basepath >> publish_cli_v0012 -> cli_tool_v0012
[cli_tool_v0012, ready_cmd] >> publish_cli_v0013 -> cli_tool_v0013
[ext_v0014, basepath] >> publish_ext_v0015 -> ext_v0015

cli_tool_v0013 >> update_pfd_ops_skill -> pfd_ops_skill_ready

cli_tool_v0013 >> i268_implement_type_field -> type_field
type_field >> implement_audit_sync -> audit_sync
cli_tool_v0013 >> i272_implement_w002_hierarchy -> w002_hierarchy
cli_tool_v0013 >> i273_implement_blocked_by -> blocked_by
cli_tool_v0013 >> implement_status_set -> status_set
status_set >> i278_implement_release_automation -> release_automation

[cli_tool_v0013, type_field, audit_sync, w002_hierarchy, blocked_by, status_set] >> publish_cli_v0014 -> cli_tool_v0014

cli_tool_v0014 >> implement_statusset_impact -> statusset_impact

cli_tool_v0014 >> implement_symmetry_hint -> symmetry_hint

[cli_tool_v0014, statusset_impact, symmetry_hint] >> publish_cli_v0015 -> cli_tool_v0015

[type_field, w002_hierarchy, blocked_by] >> integrate_spec_v0011 -> spec_v0011
spec_v0010 >>? integrate_spec_v0011

multifile_toolchain >> recode_boundary_diags -> recode

[spec_v0011, multifile_toolchain] >> implement_boundary_feedback -> boundary_feedback

cli_tool_v0015 >> i352_probe_adoption_day -> adoption_probe

cli_tool_v0015 >> i355_implement_retro_due -> retro_due_hook
cli_tool_v0015 >> i356_implement_explain_cmd -> explain_cmd
cli_tool_v0015 >> i357_define_pfd_lens_agent -> pfd_lens_agent

[explain_cmd, pfd_lens_agent] >> publish_cli_v0018 -> cli_tool_v0018
spec_v0011 >> i328_design_spec_ids -> spec_id_syntax

spec_id_syntax >> migrate_spec_id_refs -> spec_id_refs

skill_gen >> i366_distribute_marketplace -> marketplace_dist
