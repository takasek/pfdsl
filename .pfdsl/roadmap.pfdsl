  i300_spec_editorial:
    label: "spec 編集整備パス (#300)"
    description: "v0.0.11 レビューの残余 findings（F3-F22。F1 は #298、§16 表化は #299）を spec に反映する"
    status: todo
    criteria: "対象 findings が spec に反映され check-docs / gen-skill が差分なしで通過"
    location: https://github.com/takasek/pfdsl/issues/300
    updated_at: 2026-07-04T05:43:40Z
process:
  implement_version_cmd:
    label: --version コマンド実装
  write_article:
    label: 記事執筆
  draft_multifile_specs:
    label: 階層・プリセット共同起草
    description: "#5 と #6 は決定が往復で形成される相互依存のため分割せず共同設計する。共有決定は方針記録として外化"
  draft_criteria:
    label: 合否基準仕様起草
  draft_revises:
    label: 改版チェーン仕様起草
  draft_location:
    label: location/command 起草
  write_design_notes:
    label: 設計ノート執筆
  integrate_spec:
    label: 仕様統合
  implement_lints:
    label: lint実装
  implement_spec_features:
    label: 新仕様実装
  integrate_multifile:
    label: マルチファイル仕様統合
  restructure_skillgen:
    label: 生成系再構成
  publish_cli_v009:
    label: CLI v0.0.9公開
  build_obsidian_plugin:
    label: Obsidianプラグイン実装
  draft_external_stakeholders:
    label: externalStakeholders仕様起草
    description: "artifact / process の externalStakeholders フィールドを spec に定義する。型・終端監査との連携（#37）・サンプル反映を含む"
  layer_audit_assets:
    label: L3資産階層化
  implement_multifile:
    label: マルチファイル機能実装
    description: "spec v0.0.8 subflow/extends checker 実装（V021-V028）。renderer・VS Code extension は対象外。issue: https://github.com/takasek/pfdsl/issues/148"
  publish_extension:
    label: extension自動公開実装
  implement_subcommand_help:
    label: per-command --help実装
  implement_stdin:
    label: stdin対応実装
  implement_no_color:
    label: --no-color / NO_COLOR実装
  implement_json_output:
    label: --json出力実装
  publish_cli_v0010:
    label: CLI v0.0.10リリース
  implement_index_reindex:
    label: index フィールド + reindex 実装
  implement_hover_jump:
    label: hover/quickpick ジャンプ実装
  implement_run_command:
    label: process command 実行実装
  implement_group_hover:
    label: group hover メンバー一覧実装
  fix_w002_line:
    label: W002 診断行番号修正
  publish_cli_v0011:
    label: CLI v0.0.11リリース
  implement_node_sort:
    label: node 並べ替え実装
  publish_ext_v0014:
    label: extension v0.0.14リリース
  integrate_spec_v009:
    label: 仕様書 v0.0.9統合
  implement_basepath:
    label: basePath フィールド実装
    description: "spec, CLI/core, vscode-extension に basePath: フィールド対応を実装する。新フロントマターフィールド追加・location/command パス解決変更・拡張コマンド実行 cwd 変更・feature sample 追加を含む"
  integrate_spec_v0010:
    label: 仕様書 v0.0.10統合
  implement_ready_cmd:
    label: ready コマンド実装
    description: "pfd-ops スキルのステップ1計算を CLI に移す。--best/--json を含む"
  update_pfd_ops_skill:
    label: pfd-ops スキル更新
    description: "SKILL.md ワークサイクル step 1 を pfdsl ready CLI 参照に書き換え、~/.claude/skills/pfd-ops/ に反映する"
  publish_cli_v0012:
    label: CLI v0.0.12リリース
  publish_cli_v0013:
    label: CLI v0.0.13リリース
  publish_cli_v0014:
    label: CLI v0.0.14リリース
  publish_ext_v0015:
    label: extension v0.0.15リリース
  implement_type_field:
    label: type フィールド実装
    description: "frontmatter type: フィールドと ready コマンドのロードマップ型ゲートを実装する。draft_proposals 経由"
  implement_audit_sync:
    label: audit-sync コマンド実装
    description: "workflow/pipeline の todo ノードと roadmap 構築チェーンを突合するコマンド"
  implement_w002_hierarchy:
    label: W002 criteria 階層化実装
  implement_blocked_by:
    label: blockedBy フィールド実装
    description: "blockedBy: フィールドの spec 統合と CLI 対応。draft_proposals 経由"
  implement_status_set:
    label: status-set コマンド実装
  implement_statusset_impact:
    label: status-set 解放プロセス報告実装
  implement_symmetry_hint:
    label: audit 同種対称性ヒント実装
  publish_cli_v0015:
    label: CLI v0.0.15リリース
  implement_release_automation:
    label: make release roadmap 自動更新実装
  integrate_spec_v0011:
    label: 仕様書 v0.0.11統合
    description: "waiting/suspended status 分割・type フィールド・W002 source artifact 免除を spec 本文に統合する"
  recode_boundary_diags:
    label: 境界診断コード再採番
  implement_boundary_feedback:
    label: open input feedback 除外実装
    description: "computeOpenInputs の修正と spec v0.0.12 統合（proposal 経由）。発見経緯は docs/adr/0020-spec-stress-testing/"
  implement_diag_registry:
    label: 診断コードレジストリ整備
  revise_spec_editorial:
    label: spec 編集整備

tag:
  "priority:high": { style: { color: "#b60205", penwidth: "2" } }

statusStyles:
  done: { fillcolor: "#d4edda", style: filled }
  wip: { fillcolor: "#fff3cd", style: filled }
  todo: { fillcolor: "#f8f9fa", style: filled }
  waiting: { fillcolor: "#f8d7da", style: filled }
  suspended: { fillcolor: "#e2e3e5", style: filled }
---

spec_v006 >> draft_multifile_specs -> [hierarchy_spec, presets_spec, multifile_policy]

spec_v006 >> draft_criteria -> criteria_spec

spec_v006 >> draft_revises -> revises_spec

spec_v006 >> draft_location -> location_spec

spec_v006 >> write_design_notes -> design_notes

[criteria_spec, revises_spec, location_spec, design_notes, external_stakeholders_spec] >> integrate_spec -> spec_v007

spec_v006 >>? integrate_spec

[spec_v006, findings_r12, cli_tool] >> implement_lints -> lint_checker

[spec_v007, lint_checker] >> implement_spec_features -> featured_toolchain

[hierarchy_spec, presets_spec, multifile_policy, featured_toolchain] >> integrate_multifile -> spec_v008

[spec_v008, featured_toolchain] >> implement_multifile -> multifile_toolchain

skill_gen >> restructure_skillgen -> restructured_gen

cli_tool >> publish_cli_v009 -> cli_tool_v009

cli_tool >> layer_audit_assets -> audit_distribution

adr_corpus >> write_article -> i12_article

cli_tool >> build_obsidian_plugin -> i3_obsidian_plugin

spec_v006 >> draft_external_stakeholders -> external_stakeholders_spec

cli_tool >> publish_extension -> i119_published_extension

cli_tool_v009 >> implement_version_cmd -> version_cmd
cli_tool_v009 >> implement_subcommand_help -> subcommand_help
cli_tool_v009 >> implement_stdin -> stdin
cli_tool_v009 >> implement_no_color -> no_color
cli_tool_v009 >> implement_json_output -> json_output

[version_cmd, subcommand_help, stdin, no_color, json_output] >> publish_cli_v0010 -> cli_tool_v0010

cli_tool_v009 >> implement_hover_jump -> hover_jump
cli_tool_v009 >> implement_run_command -> run_command
cli_tool_v009 >> implement_group_hover -> group_hover
cli_tool_v009 >> fix_w002_line -> w002_line

cli_tool_v009 >> implement_index_reindex -> index_reindex

cli_tool_v009 >> implement_node_sort -> node_sort

[cli_tool_v0010, w002_line, index_reindex, node_sort] >> publish_cli_v0011 -> cli_tool_v0011

index_reindex >> integrate_spec_v009 -> spec_v009

[hover_jump, run_command, group_hover] >> publish_ext_v0014 -> ext_v0014

[spec_v009, cli_tool_v0011] >> implement_basepath -> basepath
[basepath, ready_cmd] >> integrate_spec_v0010 -> spec_v0010
spec_v009 >>? integrate_spec_v0010
cli_tool_v0011 >> implement_ready_cmd -> ready_cmd
basepath >> publish_cli_v0012 -> cli_tool_v0012
[cli_tool_v0012, ready_cmd] >> publish_cli_v0013 -> cli_tool_v0013
[ext_v0014, basepath] >> publish_ext_v0015 -> ext_v0015

cli_tool_v0013 >> update_pfd_ops_skill -> pfd_ops_skill_ready

cli_tool_v0013 >> implement_type_field -> i268_type_field
i268_type_field >> implement_audit_sync -> audit_sync
cli_tool_v0013 >> implement_w002_hierarchy -> i272_w002_hierarchy
cli_tool_v0013 >> implement_blocked_by -> i273_blocked_by
cli_tool_v0013 >> implement_status_set -> status_set
status_set >> implement_release_automation -> i278_release_automation

[cli_tool_v0013, i268_type_field, audit_sync, i272_w002_hierarchy, i273_blocked_by, status_set] >> publish_cli_v0014 -> cli_tool_v0014

cli_tool_v0014 >> implement_statusset_impact -> statusset_impact

cli_tool_v0014 >> implement_symmetry_hint -> symmetry_hint

[cli_tool_v0014, statusset_impact, symmetry_hint] >> publish_cli_v0015 -> cli_tool_v0015

[i268_type_field, i272_w002_hierarchy, i273_blocked_by] >> integrate_spec_v0011 -> spec_v0011
spec_v0010 >>? integrate_spec_v0011

multifile_toolchain >> recode_boundary_diags -> i297_recode

[spec_v0011, multifile_toolchain] >> implement_boundary_feedback -> i298_boundary_feedback

[i297_recode, spec_v0011] >> implement_diag_registry -> i299_diag_registry

i298_boundary_feedback >> revise_spec_editorial -> i300_spec_editorial
