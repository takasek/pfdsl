  implement_json_output:
    label: --json出力実装
    location: https://github.com/takasek/pfdsl/issues/181
  publish_cli_v0010:
    label: CLI v0.0.10リリース
  implement_index_reindex:
    label: index フィールド + reindex 実装
    location: https://github.com/takasek/pfdsl/issues/221
  implement_hover_jump:
