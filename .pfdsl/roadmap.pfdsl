  hover_jump:
    label: "hover/quickpick jump (#216)"
    description: "location/subflow/command フィールドから hover・quickpick でジャンプ"
    status: done
    criteria: location/subflow/command フィールドのジャンプが動作確認済み
  run_command:
    label: "process command 実行 (#217)"
    description: "vscode-extension でプロセスの command フィールドを統合ターミナルで実行"
    status: done
    criteria: command フィールドのターミナル実行が動作確認済み
  group_hover:
    label: "group hover メンバー一覧 (#218)"
    description: "vscode-extension でグループノードの hover にメンバー一覧を表示"
    status: done
    criteria: group ノードの hover にメンバー一覧が表示される
  basepath:
    label: "basePath フィールド実装 (#261)"
    description: "frontmatter トップレベルに basePath: フィールドを追加。command:/location: の相対パス解決基準を変更できる。未指定時は .pfdsl ファイルのディレクトリをデフォルトとして後方互換を保つ"
    status: done
    criteria: "basePath: フィールドが CLI/core/vscode-extension で動作確認済み、feature sample あり"
  status_set:
    label: "status-set コマンド (#277)"
    description: "pfdsl status-set <file> <artifact-id> <status> で artifact status を CLI から更新する"
