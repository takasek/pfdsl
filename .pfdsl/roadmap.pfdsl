  implement_run_command:
    label: process command 実行実装
    location: https://github.com/takasek/pfdsl/issues/217
  implement_group_hover:
    label: group hover メンバー一覧実装
    location: https://github.com/takasek/pfdsl/issues/218
  fix_w002_line:
