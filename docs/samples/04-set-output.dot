digraph PFDSL {
  rankdir=LR;
  newrank=true;
  label="Set output";
  labelloc="t";

  "binary" [shape=box, label="binary", penwidth="2"];
  "build" [shape=ellipse, label="build"];
  "docs" [shape=box, label="docs", penwidth="2"];
  "source" [shape=box, label="source", penwidth="2"];

  "source" -> "build";
  "build" -> "binary";
  "build" -> "docs";
}
