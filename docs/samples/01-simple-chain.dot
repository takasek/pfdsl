digraph PFDSL {
  rankdir=LR;
  newrank=true;
  label="Simple chain";
  labelloc="t";

  "design" [shape=ellipse, label="design"];
  "requirements" [shape=box, label="requirements", penwidth="2"];
  "spec" [shape=box, label="spec", penwidth="2"];

  "requirements" -> "design";
  "design" -> "spec";
}
