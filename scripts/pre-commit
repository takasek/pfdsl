#!/bin/sh
pnpm biome check --write packages/ --no-errors-on-unmatched

if ! git diff --quiet -- packages/; then
  echo "Biome formatted files. Review changes and re-stage."
  exit 1
fi

# When .pfdsl files are staged, verify snapshots are up-to-date.
# Runs vitest -u to regenerate, then fails if any snapshot file changed.
if git diff --cached --name-only | grep -q '\.pfdsl$'; then
  pnpm --filter @pfdsl/core exec vitest run -u 2>/dev/null
  if ! git diff --quiet -- packages/core/src/__snapshots__/; then
    echo "Snapshots are stale. Run 'pnpm --filter @pfdsl/core exec vitest run -u' and re-stage the snapshot file."
    exit 1
  fi
fi

# When gen-skill inputs are staged, verify the generated skill dirs are fresh.
# gen-skill.mjs is dist-free (pure file generation), so this runs without a build.
if git diff --cached --name-only | grep -qE '^(docs/|scripts/skill-template/|scripts/gen-skill\.mjs)'; then
  node scripts/gen-skill.mjs --out .claude/skills/pfdsl >/dev/null
  node scripts/gen-skill.mjs --out skills/pfdsl >/dev/null
  if ! git diff --quiet -- .claude/skills/pfdsl skills/pfdsl; then
    echo "Skill dirs are stale. Run 'make gen-skill' and re-stage the skill files."
    exit 1
  fi
fi

# When samples change, verify the deterministic .dot / README drift guard.
# It is a vitest test that imports @pfdsl/core (→ dist), so it needs a build;
# skip with a notice when dist is absent (CI always runs it after building).
if git diff --cached --name-only | grep -qE '^docs/samples/'; then
  if [ -f packages/core/dist/index.js ] && [ -f packages/graphviz-exporter/dist/index.js ]; then
    if ! pnpm --filter @pfdsl/graphviz-exporter exec vitest run index.test >/dev/null 2>&1; then
      echo "docs/samples drift: run 'make gen-samples' and re-stage .dot / README.md."
      exit 1
    fi
  else
    echo "note: skipping samples drift check (run 'pnpm -r build' to enable locally; CI verifies it)."
  fi
fi

# When the CLI source or README changes, verify the README `## CLI` generated
# block matches `pfdsl help` output. It reads packages/cli/dist/cli.js directly,
# so it needs a build; skip with a notice when dist is absent (CI verifies it).
if git diff --cached --name-only | grep -qE '^(packages/cli/src/|README\.md)'; then
  if [ -f packages/cli/dist/cli.js ]; then
    node scripts/gen-readme-cli.mjs >/dev/null
    if ! git diff --quiet -- README.md; then
      echo "README.md CLI section is stale. Run 'make gen-readme-cli' and re-stage README.md."
      exit 1
    fi
  else
    echo "note: skipping README CLI drift check (run 'pnpm -r build' to enable locally; CI verifies it)."
  fi
fi
