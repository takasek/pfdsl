// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`public API > format: matches golden canonical output for sample file (locks spec §14 ordering) 1`] = `
"---
title: Issue 依存フロー（2026-06）
description: オープン issue の依存関係と着手可能順序。issue 本体が一次情報、本ファイルは依存構造のみ管理。issue
  管理規約・同期手段は sibling roadmap.md と pfd-ops スキルの
  references/github-issues-backend.md 参照
layout:
  direction: LR
  maxWidth: 130

artifact:
  spec_v006:
    label: 仕様書 v0.0.6
    status: done
    criteria: check/fmt/graph が全サンプルにエラーなし
    location: ../docs/spec/spec.md
  findings_r12:
    label: 実践ラウンド1/2レビュー知見
    description: docs/examples の執筆・レビューで得た品質知見
    status: done
    criteria: skill_template または adr_corpus への反映が確認済み
  cli_tool:
    label: CLI 実装（現行）
    status: done
    criteria: check/fmt/graph が全サンプルに対してエラーなし、npm 公開済み
  skill_gen:
    label: スキル生成系（現行）
    description: scripts/gen-skill.mjs と docs/samples 構成。identity は
      check-gen-skill.yml が CI 強制
    status: done
    criteria: make gen-skill が差分なしで完了し、skill と gh_skill_dist が一致
  spec_v007:
    label: 仕様書 v0.0.7（統合）
    status: done
    criteria: check/fmt/graph が全サンプルにエラーなし、v0.0.7 全フィールドが spec 本文に統合済み
    location: ../docs/spec/spec.md
  spec_v008:
    label: 仕様書 v0.0.8（マルチファイル統合）
    status: done
    criteria: check/fmt/graph が全サンプルにエラーなし
    location: ../docs/spec/spec.md
  multifile_toolchain:
    label: "spec v0.0.8 実装済みツールチェーン (#148)"
    description: "subflow:/extends: の checker 実装（V021-V028）。renderer は spec v0.0.8
      の対象外（§2.9.3 はビューリンクのみ定義）。VS Code subflow ナビゲーションは
      #147。後続門番のプレースホルダ（ADR-0018）"
    status: done
    criteria: subflow/extends の checker が @pfdsl/core に実装され check コマンドで V021-V028
      が動作確認済み（renderer は対象外）
    location: https://github.com/takasek/pfdsl/issues/148
  i147_subflow_nav:
    label: "VS Code subflow ナビゲーション (#147)"
    description: "subflow: プロセスから子 .pfdsl を Cmd+Click で開く。location: との優先順位・tooltip hint 含む"
    status: todo
    criteria: subflow プロセスの Cmd+Click で子 .pfdsl が VS Code editor で開き tooltip に hint
      が表示される
    location: https://github.com/takasek/pfdsl/issues/147
    updated_at: 2026-06-21T17:48:38Z
  i137_status_lint:
    label: "status 非単調 lint (#137)"
    description: "出力 artifact が done かつ入力 artifact が done 未満を warning 検出。spec_v008
      サイクルの retro で発見した status drift 死角"
    status: todo
    criteria: status 非単調を検出する lint が実装され check で動作確認済み
    location: https://github.com/takasek/pfdsl/issues/137
    updated_at: 2026-06-20T17:56:24Z
  i138_example_check:
    label: "doc 埋込例の check 検証 (#138)"
    description: "spec.md / proposals 内の fenced pfdsl ブロックを抽出し check にかける。CI
      強制。spec_v008 サイクルの retro で発見した inline 例の無検証死角"
    status: todo
    criteria: 埋込 pfdsl 例が check 検証経路に乗り CI 強制されている
    location: https://github.com/takasek/pfdsl/issues/138
    updated_at: 2026-06-20T17:56:25Z
  published_cli:
    label: npm公開済みCLI
    description: "現行公開バージョンは npm 一次情報（ここに書かない — ドリフトするため）。詳細は
      docs/pfdsl_implementation_flow.pfdsl の cli_published 参照"
    status: done
    criteria: npm show @pfdsl/cli version が期待バージョンを返す
    location: https://www.npmjs.com/package/@pfdsl/cli
  multifile_policy:
    label: マルチファイル意味論方針
    description: "共同起草で確定した ID スコープ・継承解決順・ファイル間参照の決定記録。ファイル横断機能（#8 実装等）と仕様統合の前提資料"
    status: done
    criteria: ID スコープ・継承解決順・ファイル間参照の決定が文書化済み
    location: ../docs/spec/proposals/multifile-policy.md
  adr_corpus:
    label: "ADR 群 (docs/adr)"
    description: 方法論の設計決定記録。一覧と本数は docs/adr/README.md が一次情報（ここに数を書かない — ドリフトするため）
    status: done
    criteria: 対象判断が文書化され docs/adr/README.md の一覧に追記済み
    location: ../docs/adr/
  i12_article:
    label: "公開記事 (#12)"
    description: ADR 群を素材とした外部公開記事。依存なしで着手可能、spec v0.0.7 確定後はより充実
    status: todo
    criteria: 外部メディアに公開済みで URL が存在する
    location: https://github.com/takasek/pfdsl/issues/12
    updated_at: 2026-06-12T08:18:56Z
  i3_obsidian_plugin:
    label: "Obsidian プラグイン (#3)"
    status: todo
    criteria: Obsidian 上で .pfdsl のプレビュー・編集が動作確認済み
    location: https://github.com/takasek/pfdsl/issues/3
    updated_at: 2026-06-12T08:18:35Z
  lint_checker:
    label: "lint拡張checker (#4)"
    description: "lint 候補の完全リストは issue #4 が一次情報（本文+コメント）。ここに列挙しない — 列挙は同期漏れで腐るため"
    status: done
    criteria: "issue #4 の対象 lint がすべて実装され、check コマンドで動作確認済み"
    location: https://github.com/takasek/pfdsl/issues/4
  audit_distribution:
    label: "L3資産の階層化配布 (#43)"
    description: "audit コア + flow-sync action を skill
      同梱・配布可能化。scripts/lib/issues-flow-audit.mjs を #37 と共有するため着手順を調整。実配布フローは
      #11"
    status: done
    criteria: install/ に配布可能ファイルが揃い、CI で identity が強制されている
    location: https://github.com/takasek/pfdsl/issues/43
  criteria_spec:
    label: "合否基準仕様案 (#7)"
    status: done
    location: https://github.com/takasek/pfdsl/issues/7
    criteria: 仕様案として起草完了
  revises_spec:
    label: "改版チェーン仕様案 (#8)"
    status: done
    location: https://github.com/takasek/pfdsl/issues/8
    criteria: 仕様案として起草完了
  design_notes:
    label: "設計判断ノート・分岐なし方針 (#9)"
    status: done
    location: https://github.com/takasek/pfdsl/issues/9
    criteria: 仕様案として起草完了
  location_spec:
    label: "location/command 仕様案 (#13)"
    description: ノードと実ファイル・実行手順を結ぶメタデータ。パス解決規則のみ multifile 方針と接点
    status: done
    criteria: 仕様案として起草完了
    location: https://github.com/takasek/pfdsl/issues/13
  restructured_gen:
    label: "再構成済みスキル生成系 (#10)"
    status: done
    location: https://github.com/takasek/pfdsl/issues/10
    criteria: make gen-skill が差分なしで完了し、skill と gh_skill_dist が一致
  featured_toolchain:
    label: "spec v0.0.7 実装済みツールチェーン (#52)"
    status: done
    location: https://github.com/takasek/pfdsl/issues/52
    criteria: spec v0.0.7 の全機能が実装され、check/fmt/graph がエラーなしで動作
  external_stakeholders_spec:
    label: "externalStakeholders フィールド仕様案 (#97)"
    description: "artifact / process に外部消費者を列挙するフィールド。owner
      と対称。終端監査（#37）で消費者として扱う。ecosystem 廃止（ADR-0017）の代替手段。v0.0.7 スコープ"
    status: done
    criteria: 仕様案として起草完了
    location: https://github.com/takasek/pfdsl/issues/97
  hierarchy_spec:
    label: "階層PFD仕様案 (#5)"
    status: done
    criteria: 仕様案として起草完了
    location: https://github.com/takasek/pfdsl/issues/5
  presets_spec:
    label: "共有プリセット仕様案 (#6)"
    status: done
    criteria: 仕様案として起草完了
    location: https://github.com/takasek/pfdsl/issues/6
process:
  write_article:
    label: 記事執筆
  draft_multifile_specs:
    label: 階層・プリセット共同起草
    description: "#5 と #6 は決定が往復で形成される相互依存のため分割せず共同設計する。共有決定は方針記録として外化"
  draft_criteria:
    label: 合否基準仕様起草
  draft_revises:
    label: 改版チェーン仕様起草
  draft_location:
    label: location/command 起草
  write_design_notes:
    label: 設計ノート執筆
  integrate_spec:
    label: 仕様統合
  implement_lints:
    label: lint実装
  implement_spec_features:
    label: 新仕様実装
  integrate_multifile:
    label: マルチファイル仕様統合
  restructure_skillgen:
    label: 生成系再構成
  publish_cli:
    label: CLI公開
  build_obsidian_plugin:
    label: Obsidianプラグイン実装
  draft_external_stakeholders:
    label: externalStakeholders仕様起草
    description: "artifact / process の externalStakeholders フィールドを spec
      に定義する。型・終端監査との連携（#37）・サンプル反映を含む"
  layer_audit_assets:
    label: L3資産階層化
  implement_multifile:
    label: マルチファイル機能実装
    description: "spec v0.0.8 subflow/extends checker 実装（V021-V028）。renderer・VS Code
      extension は対象外。issue: https://github.com/takasek/pfdsl/issues/148"
  implement_subflow_nav:
    label: subflowナビゲーション実装
  implement_status_lint:
    label: status非単調lint実装
  implement_example_check:
    label: 埋込例check実装

tag:
  "priority:high": { style: { color: "#b60205", penwidth: "2" } }

statusStyles:
  done: { fillcolor: "#d4edda", style: filled }
  wip: { fillcolor: "#fff3cd", style: filled }
  todo: { fillcolor: "#f8f9fa", style: filled }
  blocked: { fillcolor: "#f8d7da", style: filled }
---

spec_v006 >> draft_multifile_specs
draft_multifile_specs -> hierarchy_spec
