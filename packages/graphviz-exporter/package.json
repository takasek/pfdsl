{
	"name": "@pfdsl/graphviz-exporter",
	"version": "0.0.1",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@pfdsl/core": "workspace:*"
	},
	"peerDependencies": {
		"puppeteer": ">=20.0.0"
	},
	"peerDependenciesMeta": {
		"puppeteer": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=18"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/node": "^20.0.0",
		"tsup": "^8.0.0",
		"vitest": "^1.6.0"
	}
}
