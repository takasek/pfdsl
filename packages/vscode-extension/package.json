{
	"name": "pfdsl",
	"displayName": "PFDSL",
	"description": "A DSL to define and visualize PFD (Process Flow Diagram) as code",
	"version": "0.0.16",
	"publisher": "takasek",
	"repository": {
		"type": "git",
		"url": "https://github.com/takasek/pfdsl"
	},
	"engines": {
		"vscode": "^1.85.0",
		"node": ">=18"
	},
	"categories": [
		"Programming Languages",
		"Visualization"
	],
	"main": "./dist/extension.cjs",
	"contributes": {
		"languages": [
			{
				"id": "pfdsl",
				"aliases": [
					"PFDSL",
					"pfdsl"
				],
				"extensions": [
					".pfdsl"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "pfdsl",
				"scopeName": "source.pfdsl",
				"path": "./syntaxes/pfdsl.tmLanguage.json",
				"embeddedLanguages": {
					"meta.embedded.block.frontmatter": "yaml"
				}
			}
		],
		"commands": [
			{
				"command": "pfdsl.format",
				"title": "PFDSL: Format Document"
			},
			{
				"command": "pfdsl.preview",
				"title": "PFDSL: Open Preview to the Side",
				"icon": "$(open-preview)"
			},
			{
				"command": "pfdsl.export",
				"title": "PFDSL: Export…"
			},
			{
				"command": "pfdsl.normalize",
				"title": "PFDSL: Show Normalized Edges"
			},
			{
				"command": "pfdsl.diff",
				"title": "PFDSL: Diff..."
			},
			{
				"command": "pfdsl.clearDiff",
				"title": "PFDSL: Clear Diff"
			},
			{
				"command": "pfdsl.jumpToDefinition",
				"title": "PFDSL: Go to Frontmatter Definition"
			},
			{
				"command": "pfdsl.sortMeta",
				"title": "PFDSL: Sort Node Definitions…"
			}
		],
		"keybindings": [
			{
				"command": "pfdsl.jumpToDefinition",
				"key": "alt+f12",
				"when": "editorLangId == pfdsl"
			}
		],
		"menus": {
			"editor/title": [
				{
					"when": "editorLangId == pfdsl",
					"command": "pfdsl.preview",
					"group": "navigation"
				}
			],
			"editor/context": [
				{
					"when": "editorLangId == pfdsl",
					"command": "pfdsl.jumpToDefinition",
					"group": "navigation"
				}
			]
		}
	},
	"scripts": {
		"build": "node esbuild.config.mjs",
		"watch": "node esbuild.config.mjs --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@hpcc-js/wasm": "^2.18.0",
		"@pfdsl/core": "workspace:*",
		"@pfdsl/graphviz-exporter": "workspace:*",
		"@pfdsl/metadata-exporter": "workspace:*",
		"@pfdsl/preview-engine": "workspace:*"
	},
	"peerDependencies": {
		"puppeteer": ">=20.0.0"
	},
	"peerDependenciesMeta": {
		"puppeteer": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"esbuild": "^0.21.0",
		"jsdom": "^24.0.0",
		"vitest": "^1.6.0"
	}
}
